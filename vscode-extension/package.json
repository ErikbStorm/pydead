{
  "name": "pydead",
  "displayName": "PyDead — Python Dead Code",
  "description": "Highlight unused Python functions, classes, methods, and variables across the whole workspace folder.",
  "version": "0.1.0",
  "publisher": "pydead",
  "license": "MIT",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1a1b26",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ErikbStorm/pydead.git"
  },
  "homepage": "https://github.com/ErikbStorm/pydead",
  "bugs": {
    "url": "https://github.com/ErikbStorm/pydead/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Programming Languages"
  ],
  "keywords": [
    "python",
    "dead code",
    "unused",
    "linter",
    "ruff"
  ],
  "activationEvents": [
    "onLanguage:python",
    "workspaceContains:**/*.py"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pydead.find",
        "title": "PyDead: Find Dead Code"
      },
      {
        "command": "pydead.fixAll",
        "title": "PyDead: Fix All (workspace)"
      },
      {
        "command": "pydead.fixFile",
        "title": "PyDead: Fix All in File"
      },
      {
        "command": "pydead.keepSelection",
        "title": "PyDead: Keep (mark as used)"
      },
      {
        "command": "pydead.keepSelectionCodeOnly",
        "title": "PyDead: Keep (this rule code only)"
      },
      {
        "command": "pydead.reportFalsePositive",
        "title": "PyDead: Report False Positive (GitHub Issue)"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "pydead.keepSelection",
          "when": "editorLangId == python && resourceScheme == file",
          "group": "pydead@1"
        },
        {
          "command": "pydead.reportFalsePositive",
          "when": "editorLangId == python && resourceScheme == file",
          "group": "pydead@2"
        },
        {
          "command": "pydead.fixFile",
          "when": "editorLangId == python && resourceScheme == file",
          "group": "pydead@3"
        }
      ],
      "commandPalette": [
        {
          "command": "pydead.keepSelection",
          "when": "editorLangId == python"
        },
        {
          "command": "pydead.keepSelectionCodeOnly",
          "when": "editorLangId == python"
        },
        {
          "command": "pydead.reportFalsePositive",
          "when": "editorLangId == python"
        },
        {
          "command": "pydead.fixFile",
          "when": "editorLangId == python"
        },
        {
          "command": "pydead.fixAll",
          "when": "editorLangId == python"
        }
      ]
    },
    "configuration": {
      "title": "PyDead",
      "properties": {
        "pydead.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable PyDead diagnostics for Python files."
        },
        "pydead.path": {
          "type": "string",
          "default": "",
          "description": "Path to the pydead binary. Empty = use bundled binary, then PATH."
        },
        "pydead.minConfidence": {
          "type": "number",
          "default": 70,
          "minimum": 0,
          "maximum": 100,
          "description": "Minimum confidence (0–100) for reporting dead code."
        },
        "pydead.severity": {
          "type": "string",
          "enum": [
            "Hint",
            "Information",
            "Warning",
            "Error"
          ],
          "default": "Hint",
          "description": "Diagnostic severity for unused definitions."
        },
        "pydead.runOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Re-analyze the workspace when a Python file is saved."
        },
        "pydead.issueRepo": {
          "type": "string",
          "default": "https://github.com/ErikbStorm/pydead",
          "description": "GitHub repository URL for false-positive reports. Must be https://github.com/owner/repo only (no other hosts or paths)."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "^5.3.3"
  }
}
